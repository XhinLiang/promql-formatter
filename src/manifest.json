{
  "manifest_version": 3,
  "name": "PromQL Formatter",
  "version": "1.0.0",
  "description": "Prettify PromQL queries locally in your browser — VictoriaMetrics & Prometheus backends, no data leaves your machine.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
