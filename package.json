{
  "name": "promql-formatter",
  "version": "1.0.0",
  "description": "Chrome extension that prettifies PromQL queries locally via Go/WebAssembly.",
  "private": true,
  "license": "Apache-2.0",
  "homepage": "https://github.com/XhinLiang/promql-formatter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XhinLiang/promql-formatter.git"
  },
  "bugs": {
    "url": "https://github.com/XhinLiang/promql-formatter/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "bash scripts/build-wasm.sh",
    "build:wasm": "bash scripts/build-wasm.sh",
    "pretest": "npm run build:wasm",
    "test": "node --test \"test/**/*.test.mjs\"",
    "package": "bash scripts/package-extension.sh",
    "version": "node scripts/sync-version.mjs && git add src/manifest.json"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.2.5"
  }
}
